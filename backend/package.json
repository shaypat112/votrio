{
  "name": "votrio",
  "version": "0.1.0",
  "description": "AI-powered terminal trace analyzer, security scanner, and code quality tool",
  "keywords": [
    "cli",
    "ai",
    "debugging",
    "security",
    "stack-trace",
    "devtools"
  ],
  "homepage": "https://votrio.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/votrio/votrio"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "votrio": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.1.0",
    "glob": "^11.0.0",
    "inquirer": "^10.1.0",
    "ora": "^8.0.1",
    "strip-ansi": "^7.1.0",
    "update-notifier": "^7.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/update-notifier": "^6.0.8",
    "tsup": "^8.0.0",
    "build": "tsup src/index.ts --format esm --dts --clean --banner.js '#!/usr/bin/env node'",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
