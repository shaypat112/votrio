# Public application configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase access used by account deletion and team administration
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Scanning and AI
GITHUB_TOKEN=github_pat_optional_for_public_scan_rate_limits
MISTRAL_API_KEY=your-mistral-key
MISTRAL_MODEL=mistral-large-latest

# Billing
STRIPE_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_PRICE_PRO=price_xxxxx
STRIPE_PRICE_TEAM=price_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Email
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=Votrio <notifications@example.com>
WAITLIST_NOTIFY_EMAIL=team@example.com
NOTIFICATION_EMAIL_WEBHOOK_URL=https://example.com/webhooks/notifications
NOTIFICATION_EMAIL_WEBHOOK_TOKEN=optional-webhook-token

# Platform administrator identity; leave all blank to disable admin access
ADMIN_PROFILE_USERNAME=
ADMIN_FULL_NAME=
ADMIN_GITHUB_LOGIN=
